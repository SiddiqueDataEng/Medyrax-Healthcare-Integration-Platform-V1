{
  "name": "Medyrax-cdk",
  "version": "1.0.0",
  "description": "Medyrax™ Platform — AWS CDK TypeScript infrastructure",
  "main": "bin/app.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "cdk": "cdk",
    "synth": "cdk synth",
    "synth:dev": "cdk synth --context env=dev",
    "synth:staging": "cdk synth --context env=staging",
    "synth:prod": "cdk synth --context env=prod",
    "deploy:dev": "cdk deploy --context env=dev --all",
    "deploy:staging": "cdk deploy --context env=staging --all --require-approval broadening",
    "diff:dev": "cdk diff --context env=dev",
    "lint": "eslint 'src/**/*.ts' 'bin/**/*.ts' 'test/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' 'bin/**/*.ts' 'test/**/*.ts' --fix"
  },
  "devDependencies": {
    "@types/jest": "29.5.12",
    "@types/node": "20.12.12",
    "@typescript-eslint/eslint-plugin": "7.10.0",
    "@typescript-eslint/parser": "7.10.0",
    "aws-cdk": "2.144.0",
    "eslint": "8.57.0",
    "jest": "29.7.0",
    "ts-jest": "29.1.4",
    "typescript": "5.4.5",
    "fast-check": "3.19.0"
  },
  "dependencies": {
    "aws-cdk-lib": "2.144.0",
    "constructs": "10.3.0",
    "source-map-support": "0.5.21"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/test"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "collectCoverageFrom": [
      "lib/**/*.ts",
      "bin/**/*.ts",
      "!**/*.d.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  }
}
